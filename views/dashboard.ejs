<%- include("partials/header", { title: "Resultados Análisis de Aceite Centrales Wärtsilä", flash: flash }) %>

<section class="card">
  <h2>Buscar muestras por equipo</h2>
  <form method="POST" action="/samples/search" class="form-grid two-cols">
    <div class="full-width area-selector">
      <span class="area-label">Área</span>
      <details class="area-dropdown">
        <summary>Seleccionar área(s)</summary>
        <div class="area-options">
          <% areaOptions.forEach(function (area) { %>
            <label class="area-option">
              <input type="checkbox" name="areas" value="<%= area %>" <%= Array.isArray(form.areas) && form.areas.includes(area) ? "checked" : "" %>>
              <span><%= area %></span>
            </label>
          <% }); %>
        </div>
      </details>
      <div class="area-selected-list">
        <% if (Array.isArray(form.areas) && form.areas.length > 0) { %>
          <% form.areas.forEach(function (selectedArea) { %>
            <span class="area-chip"><%= selectedArea %></span>
          <% }); %>
        <% } else { %>
          <span class="area-chip muted">Sin áreas seleccionadas</span>
        <% } %>
      </div>
    </div>

    <label class="full-width">
      Equipo
      <select id="equipmentId" name="equipmentId" required>
        <option value="">Seleccionar equipo...</option>
        <% equipmentOptions.forEach(function (item) { %>
          <option value="<%= item.id %>" data-area="<%= item.area %>" <%= String(form.equipmentId) === String(item.id) ? "selected" : "" %>><%= item.label %></option>
        <% }); %>
      </select>
    </label>

    <label>
      Estado de resultado
      <select name="resultStatus">
        <option value="ALL" <%= form.resultStatus === "ALL" ? "selected" : "" %>>Todos</option>
        <option value="NORMAL" <%= form.resultStatus === "NORMAL" ? "selected" : "" %>>Normal</option>
        <option value="CAUTION" <%= form.resultStatus === "CAUTION" ? "selected" : "" %>>Caution</option>
        <option value="ABNORMAL" <%= form.resultStatus === "ABNORMAL" ? "selected" : "" %>>Abnormal</option>
        <option value="SEVERE" <%= form.resultStatus === "SEVERE" ? "selected" : "" %>>Severe</option>
      </select>
    </label>

    <label>
      Operación / Límites
      <select name="operationMode">
        <option value="GAS" <%= operationMode === "GAS" ? "selected" : "" %>>Gas</option>
        <option value="HFO" <%= operationMode === "HFO" ? "selected" : "" %>>HFO</option>
      </select>
    </label>

    <label>
      Fecha resultado desde
      <input type="date" name="sinceResultDate" value="<%= form.sinceResultDate %>">
    </label>

    <label>
      Fecha resultado hasta
      <input type="date" name="untilResultDate" value="<%= form.untilResultDate %>">
    </label>

    <label>
      Texto libre
      <input type="text" name="generalSearch" value="<%= form.generalSearch %>" placeholder="Nro muestra, compartimento, cliente, etc.">
    </label>

    <label>
      Pagina
      <input type="number" name="page" min="1" value="<%= form.page %>">
    </label>

    <label>
      Tamaño pagina
      <input type="number" name="pageSize" min="1" max="50" value="<%= form.pageSize %>">
    </label>

    <div class="full-width form-actions-row">
      <button type="submit">Buscar muestras</button>
    </div>
  </form>

  <script>
    (function () {
      const areaCheckboxes = Array.from(document.querySelectorAll('input[name="areas"]'));
      const equipmentSelect = document.getElementById("equipmentId");
      const selectedList = document.querySelector(".area-selected-list");
      if (!areaCheckboxes.length || !equipmentSelect || !selectedList) {
        return;
      }

      const normalize = (value) =>
        String(value || "")
          .trim()
          .toLowerCase()
          .normalize("NFD")
          .replace(/[\u0300-\u036f]/g, "");

      const renderSelectedChips = () => {
        const selected = areaCheckboxes
          .filter((item) => item.checked)
          .map((item) => item.value);

        if (!selected.length) {
          selectedList.innerHTML = '<span class="area-chip muted">Sin áreas seleccionadas</span>';
          return;
        }

        selectedList.innerHTML = selected
          .map((item) => `<span class="area-chip">${item}</span>`)
          .join("");
      };

      const filterEquipmentOptions = () => {
        const selectedSet = new Set(
          areaCheckboxes.filter((item) => item.checked).map((item) => normalize(item.value))
        );
        const options = Array.from(equipmentSelect.options);
        let hasCurrentOptionVisible = false;

        options.forEach((option, index) => {
          if (index === 0) {
            option.hidden = false;
            return;
          }

          const optionArea = normalize(option.dataset.area);
          const visible = selectedSet.size === 0 || selectedSet.has(optionArea);
          option.hidden = !visible;

          if (visible && option.value === equipmentSelect.value) {
            hasCurrentOptionVisible = true;
          }
        });

        if (!hasCurrentOptionVisible) {
          equipmentSelect.value = "";
        }
      };

      const syncAreaFilters = () => {
        renderSelectedChips();
        filterEquipmentOptions();
      };

      areaCheckboxes.forEach((checkbox) => {
        checkbox.addEventListener("change", syncAreaFilters);
      });

      syncAreaFilters();
    })();
  </script>
</section>

<% if (selectedEquipment) { %>
  <section class="card">
    <h2>Equipo seleccionado</h2>
    <div class="stats-grid equipment-grid">
      <article class="stat-card"><span class="label">ID</span><strong><%= selectedEquipment.id %></strong></article>
      <article class="stat-card"><span class="label">Modelo</span><strong><%= selectedEquipment.model || "-" %></strong></article>
      <article class="stat-card"><span class="label">Tag</span><strong><%= selectedEquipment.tag || "-" %></strong></article>
      <article class="stat-card"><span class="label">Serie</span><strong><%= selectedEquipment.serial || "-" %></strong></article>
      <article class="stat-card"><span class="label">Area</span><strong><%= selectedEquipment.area || "-" %></strong></article>
      <article class="stat-card"><span class="label">Sector</span><strong><%= selectedEquipment.sector || "-" %></strong></article>
      <article class="stat-card"><span class="label">Cliente</span><strong><%= selectedEquipment.customer || "-" %></strong></article>
      <article class="stat-card"><span class="label">Sitio / Obra</span><strong><%= selectedEquipment.site || "-" %></strong></article>
    </div>
  </section>
<% } %>

<section class="card">
  <h2>Resumen de la busqueda</h2>
  <div class="stats-grid">
    <article class="stat-card"><span class="label">Coincidencias</span><strong><%= searchMetrics.totalMatches %></strong></article>
    <article class="stat-card"><span class="label">Registros en esta pagina</span><strong><%= searchMetrics.pageCount %></strong></article>
    <article class="stat-card"><span class="label">Leidos</span><strong><%= searchMetrics.readCount %></strong></article>
    <article class="stat-card"><span class="label">No leidos</span><strong><%= searchMetrics.unreadCount %></strong></article>
    <article class="stat-card status-normal"><span class="label">Normal</span><strong><%= searchMetrics.statusCount.NORMAL %></strong></article>
    <article class="stat-card status-caution"><span class="label">Caution</span><strong><%= searchMetrics.statusCount.CAUTION %></strong></article>
    <article class="stat-card status-abnormal"><span class="label">Abnormal</span><strong><%= searchMetrics.statusCount.ABNORMAL %></strong></article>
    <article class="stat-card status-severe"><span class="label">Severe</span><strong><%= searchMetrics.statusCount.SEVERE %></strong></article>
  </div>
</section>

<section class="card">
  <h2>Resultados de muestras</h2>

  <% if (searchResult && Array.isArray(searchResult.results) && searchResult.results.length > 0) { %>
    <div class="table-wrapper samples-table-wrapper">
      <table class="samples-results-table">
        <thead>
          <tr>
            <th>Muestra</th>
            <th>Estado</th>
            <th>Fecha resultado</th>
            <th>Lectura</th>
            <th>Compartimento</th>
            <th>Equipo</th>
            <th>Acción</th>
          </tr>
        </thead>
        <tbody>
          <% searchResult.results.forEach(function (item) { %>
            <tr>
              <td><%= item.sampleNumber || "-" %></td>
              <td>
                <% const status = item.validResult?.resultStatus || item.result || "UNKNOWN"; %>
                <span class="status-pill <%= status.toLowerCase() %>"><%= status %></span>
              </td>
              <td><%= item.resultDate || "-" %></td>
              <td><%= item.readingStatus === true ? "Leido" : item.readingStatus === false ? "No leido" : "-" %></td>
              <td><%= item.compartment?.name || item.collectionData?.compartmentName || "-" %></td>
              <td><%= item.equipment?.model || "-" %></td>
              <td>
                <form method="POST" action="/samples/view">
                  <input type="hidden" name="sampleNumber" value="<%= item.sampleNumber %>">
                  <button type="submit" class="secondary btn-compact">Ver</button>
                </form>
                <a class="secondary-link btn-compact" href="/samples/<%= item.sampleNumber %>/pdf">PDF</a>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  <% } else { %>
    <p class="subtitle">Aun no hay resultados para mostrar.</p>
  <% } %>
</section>

<section class="card">
  <h2>Comparativo ultimas 10 muestras del equipo</h2>

  <% if (sampleDetail) { %>
    <p class="subtitle">Muestra seleccionada: <strong><%= selectedSampleNumber %></strong></p>
    <p class="subtitle">Límites aplicados: <strong><%= operationMode %></strong></p>
    <p class="subtitle"><a class="secondary-link" href="/samples/<%= selectedSampleNumber %>/pdf">Exportar muestra seleccionada a PDF</a></p>

    <div class="stats-grid equipment-grid">
      <article class="stat-card"><span class="label">Resultado</span><strong><%= sampleDetail.result || sampleDetail.validResult?.resultStatus || "-" %></strong></article>
      <article class="stat-card"><span class="label">Fecha resultado</span><strong><%= sampleDetail.resultDate || sampleDetail.validResult?.resultDate || "-" %></strong></article>
      <article class="stat-card"><span class="label">Responsable</span><strong><%= sampleDetail.responsable || sampleDetail.validResult?.responsible?.name || "-" %></strong></article>
      <article class="stat-card"><span class="label">Modelo equipo</span><strong><%= sampleDetail.equipment?.model || "-" %></strong></article>
      <article class="stat-card"><span class="label">Compartimento</span><strong><%= sampleDetail.compartment?.name || sampleDetail.sampleData?.compartmentName || "-" %></strong></article>
      <article class="stat-card"><span class="label">Cliente</span><strong><%= sampleDetail.customer?.name || "-" %></strong></article>
      <article class="stat-card"><span class="label">Sitio</span><strong><%= sampleDetail.site?.name || sampleDetail.equipment?.site?.name || "-" %></strong></article>
      <article class="stat-card"><span class="label">Operacion</span><strong><%= sampleDetail.operation?.name || "-" %></strong></article>
    </div>

    <% if (Array.isArray(comparisonRows) && comparisonRows.length > 0) { %>
      <h3 class="section-gap-title">Datos de la Muestra</h3>
      <div class="table-wrapper">
        <table class="comparison-table">
          <thead>
            <tr>
              <th colspan="8">Datos de la muestra</th>
              <th colspan="13">Desgaste</th>
              <th colspan="4">Contaminantes</th>
              <th colspan="1">Agua</th>
            </tr>
            <tr>
              <th>Muestra</th>
              <th>Status</th>
              <th>Muestreo</th>
              <th>Recibido</th>
              <th>Resultado</th>
              <th>Horometro</th>
              <th>Cambio?</th>
              <th>Adicion</th>
              <th>Fe</th>
              <th>Cu</th>
              <th>Cr</th>
              <th>Pb</th>
              <th>Sn</th>
              <th>Ni</th>
              <th>Mo</th>
              <th>Ti</th>
              <th>V</th>
              <th>Mn</th>
              <th>Cd</th>
              <th>Ag</th>
              <th>PQI</th>
              <th>Si</th>
              <th>Al</th>
              <th>Na</th>
              <th>K</th>
              <th>Agua</th>
            </tr>
          </thead>
          <tbody>
            <% comparisonRows.forEach(function (row) { %>
              <tr>
                <td><%= row.sampleNumber %></td>
                <td><span class="status-pill <%= String(row.status || 'UNKNOWN').toLowerCase() %>"><%= row.status %></span></td>
                <td><%= row.sampledDate %></td>
                <td><%= row.receivedDate %></td>
                <td><%= row.resultDate %></td>
                <td><%= row.hourMeter %></td>
                <td><%= row.oilChanged %></td>
                <td><%= row.oilAdded %></td>
                <td class="<%= overLimit('desgaste','fe',row.desgaste.fe) ? 'limit-hit' : '' %>"><%= row.desgaste.fe %></td>
                <td class="<%= overLimit('desgaste','cu',row.desgaste.cu) ? 'limit-hit' : '' %>"><%= row.desgaste.cu %></td>
                <td class="<%= overLimit('desgaste','cr',row.desgaste.cr) ? 'limit-hit' : '' %>"><%= row.desgaste.cr %></td>
                <td class="<%= overLimit('desgaste','pb',row.desgaste.pb) ? 'limit-hit' : '' %>"><%= row.desgaste.pb %></td>
                <td class="<%= overLimit('desgaste','sn',row.desgaste.sn) ? 'limit-hit' : '' %>"><%= row.desgaste.sn %></td>
                <td class="<%= overLimit('desgaste','ni',row.desgaste.ni) ? 'limit-hit' : '' %>"><%= row.desgaste.ni %></td>
                <td><%= row.desgaste.mo %></td>
                <td><%= row.desgaste.ti %></td>
                <td class="<%= overLimit('desgaste','v',row.desgaste.v) ? 'limit-hit' : '' %>"><%= row.desgaste.v %></td>
                <td><%= row.desgaste.mn %></td>
                <td><%= row.desgaste.cd %></td>
                <td><%= row.desgaste.ag %></td>
                <td><%= row.desgaste.pqi %></td>
                <td class="<%= overLimit('contaminantes','si',row.contaminantes.si) ? 'limit-hit' : '' %>"><%= row.contaminantes.si %></td>
                <td class="<%= overLimit('contaminantes','al',row.contaminantes.al) ? 'limit-hit' : '' %>"><%= row.contaminantes.al %></td>
                <td class="<%= overLimit('contaminantes','na',row.contaminantes.na) ? 'limit-hit' : '' %>"><%= row.contaminantes.na %></td>
                <td><%= row.contaminantes.k %></td>
                <td class="<%= overLimit('agua','valor',row.agua.valor) ? 'limit-hit' : '' %>"><%= row.agua.valor %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

      <h3>Condiciones del fluido / Aditivos</h3>
      <div class="table-wrapper">
        <table class="comparison-table">
          <thead>
            <tr>
              <th colspan="11">Condiciones del fluido</th>
              <th colspan="6">Aditivos</th>
            </tr>
            <tr>
              <th>Muestra</th>
              <th>Fluido</th>
              <th>Análisis visual</th>
              <th>Viscosidad 100°C</th>
              <th>Punto de inflamación</th>
              <th>TAN</th>
              <th>BN <small><%= limitRuleLabel("condiciones","bn") %></small></th>
              <th>Hollín-FTIR</th>
              <th>Nitración-FTIR</th>
              <th>Oxidación-FTIR</th>
              <th>Sulfatación-FTIR</th>
              <th>P</th>
              <th>Zn</th>
              <th>Ca</th>
              <th>Mg</th>
              <th>B</th>
              <th>Ba</th>
            </tr>
          </thead>
          <tbody>
            <% comparisonRows.forEach(function (row) { %>
              <tr>
                <td><%= row.sampleNumber %></td>
                <td><%= row.fluidName %></td>
                <td><%= row.condiciones.analisisVisual %></td>
                <td><%= row.condiciones.v100 %></td>
                <td><%= row.condiciones.flash %></td>
                <td><%= row.condiciones.tan %></td>
                <td class="<%= overLimit('condiciones','bn',row.condiciones.bn) ? 'limit-hit' : '' %>"><%= row.condiciones.bn %></td>
                <td><%= row.condiciones.hollin %></td>
                <td><%= row.condiciones.nitracao %></td>
                <td><%= row.condiciones.oxidacao %></td>
                <td><%= row.condiciones.sulfatacao %></td>
                <td><%= row.aditivos.p %></td>
                <td><%= row.aditivos.zn %></td>
                <td><%= row.aditivos.ca %></td>
                <td><%= row.aditivos.mg %></td>
                <td><%= row.aditivos.b %></td>
                <td><%= row.aditivos.ba %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

      <% if (trendChartsData && Array.isArray(trendChartsData.charts) && trendChartsData.charts.length > 0) { %>
        <h3>Gráficas de tendencia (últimas 10 muestras)</h3>
        <div class="trend-grid">
          <% trendChartsData.charts.forEach(function (chart) { %>
            <article class="trend-card">
              <h4><%= chart.title %></h4>
              <div class="trend-canvas-wrap">
                <canvas id="trend-chart-<%= chart.id %>"></canvas>
              </div>
            </article>
          <% }); %>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
        <script>
          (function () {
            const trendData = <%- JSON.stringify(trendChartsData) %>;
            if (!window.Chart || !trendData || !Array.isArray(trendData.charts)) {
              return;
            }

            const labels = Array.isArray(trendData.labels) ? trendData.labels : [];
            trendData.charts.forEach((chart) => {
              const canvas = document.getElementById(`trend-chart-${chart.id}`);
              if (!canvas) {
                return;
              }

              const datasets = (chart.datasets || []).map((dataset) => ({
                label: dataset.label,
                data: dataset.data,
                borderColor: dataset.borderColor,
                backgroundColor: dataset.backgroundColor,
                fill: false,
                spanGaps: true,
                tension: 0.28,
                pointRadius: 3,
                pointHoverRadius: 5,
                borderWidth: 2,
              }));

              if (!datasets.length) {
                return;
              }

              new Chart(canvas, {
                type: "line",
                data: {
                  labels,
                  datasets,
                },
                options: {
                  responsive: true,
                  maintainAspectRatio: false,
                  interaction: {
                    mode: "nearest",
                    intersect: false,
                  },
                  plugins: {
                    legend: {
                      position: "bottom",
                    },
                  },
                  scales: {
                    x: {
                      ticks: { color: "#334966" },
                      grid: { color: "rgba(0, 59, 112, 0.12)" },
                    },
                    y: {
                      ticks: { color: "#334966" },
                      grid: { color: "rgba(0, 59, 112, 0.12)" },
                    },
                  },
                },
              });
            });
          })();
        </script>
      <% } %>
    <% } else { %>
      <p class="subtitle">No fue posible armar la comparación de últimas 10 muestras para este equipo.</p>
    <% } %>

    <details>
      <summary>Ver JSON completo</summary>
      <pre><%= JSON.stringify(sampleDetail, null, 2) %></pre>
    </details>
  <% } else { %>
    <p class="subtitle">Selecciona una muestra para ver la tabla comparativa y las gráficas de últimas 10 muestras del equipo.</p>
  <% } %>
</section>

<section class="card">
  <h2>Pestaña: Límites (resumen)</h2>
  <div class="table-wrapper">
    <table class="comparison-table">
      <thead>
        <tr>
          <th>Sección</th>
          <th>Parámetro</th>
          <th>Límite GAS</th>
          <th>Límite HFO</th>
          <th>Fuente</th>
        </tr>
      </thead>
      <tbody>
        <% limitSummaryRows.forEach(function (row) { %>
          <tr>
            <td><%= row.section %></td>
            <td><%= row.parameter %></td>
            <td><%= row.gas %></td>
            <td><%= row.hfo %></td>
            <td><%= row.source %></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</section>

<%- include("partials/footer") %>

